{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "lavy/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "node",
    "downlevelIteration": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2015", "ES2017", "ESNext"]
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/src/**/*.d.ts",
    "examples/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "build", "coverage", "**/*.spec.ts", "**/*.test.ts"]
}
